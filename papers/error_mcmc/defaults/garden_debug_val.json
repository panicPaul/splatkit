{
  "preset": "garden_debug_val",
  "scene": {
    "path": "dataset/mipnerf360/garden",
    "image_root": null,
    "undistort_output_dir": null,
    "align_horizon": true
  },
  "data": {
    "camera_sensor_id": null,
    "image_scale_factor": 0.1,
    "cache_resized_images": true,
    "resized_image_cache_root": null,
    "max_resized_image_caches": 4,
    "split_target": "val",
    "split_every_n": 8,
    "materialization_stage": "prepared",
    "materialization_mode": "eager",
    "materialization_num_workers": 8,
    "normalize_images": true,
    "interpolation": "bicubic"
  },
  "training": {
    "runtime": {
      "device": "cuda",
      "seed": 0,
      "max_steps": 3000
    },
    "batching": {
      "batch_size": 1,
      "shuffle": true,
      "num_workers": 8,
      "persistent_workers": true,
      "pin_memory": true
    },
    "initialization": {
      "sh_degree": 3,
      "use_mcmc": true,
      "default_color": [
        0.5,
        0.5,
        0.5
      ]
    },
    "render": {
      "backend": "faster_gs.fastgs",
      "near_plane": 0.2,
      "far_plane": 10000.0,
      "compact_box_scale": 0.5,
      "background_color": [
        0.0,
        0.0,
        0.0
      ],
      "return_alpha": false
    },
    "densification": {
      "error_mcmc": {
        "refine_every": 100,
        "start_iter": 100,
        "stop_iter": 900,
        "min_opacity": 0.005,
        "max_primitives": 200000,
        "cap_growth_factor": 1.05,
        "inject_position_noise": false,
        "noise_lr_scale": 500000.0,
        "loss_thresh": 0.06,
        "probe_view_count": 6,
        "score_aggregation": "topk_mean",
        "score_top_k": 2,
        "opacity_floor": 0.05,
        "opacity_power": 0.5,
        "normalize_error_score": false
      },
      "morton": {
        "schedule": {
          "start_iteration": 0,
          "end_iteration": 1000,
          "frequency": 500
        }
      },
      "final_cleanup": {
        "min_opacity": 0.00392156862745098
      }
    },
    "checkpoint": {
      "output_dir": "checkpoints/papers/error_mcmc/garden_debug_val/faster_gs.fastgs",
      "export_ply": true
    },
    "mip_splatting": {
      "enabled": true,
      "screen_filter_enabled": true,
      "three_dimensional_filter": {
        "recompute_schedule": {
          "start_iteration": 1000,
          "end_iteration": 2989,
          "frequency": 100
        },
        "near_plane": 0.2
      }
    }
  }
}
