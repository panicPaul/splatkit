{
  "preset": "garden_baseline",
  "scene": {
    "path": "dataset/mipnerf360/garden",
    "image_root": null,
    "undistort_output_dir": null,
    "align_horizon": true
  },
  "data": {
    "camera_sensor_id": null,
    "image_scale_factor": 0.25,
    "cache_resized_images": true,
    "resized_image_cache_root": null,
    "max_resized_image_caches": 4,
    "split_target": "train",
    "split_every_n": 8,
    "materialization_stage": "none",
    "materialization_mode": "lazy",
    "materialization_num_workers": 0,
    "normalize_images": true,
    "interpolation": "bicubic"
  },
  "training": {
    "runtime": {
      "device": "cuda",
      "seed": 0,
      "max_steps": 30000
    },
    "batching": {
      "batch_size": 1,
      "shuffle": true,
      "num_workers": 4,
      "persistent_workers": true,
      "pin_memory": true
    },
    "initialization": {
      "sh_degree": 3,
      "use_mcmc": false,
      "default_color": [
        0.5,
        0.5,
        0.5
      ]
    },
    "render": {
      "backend": "adapter.fastergs",
      "near_plane": 0.2,
      "far_plane": 10000.0,
      "proper_antialiasing": true,
      "background_color": [
        0.0,
        0.0,
        0.0
      ],
      "return_alpha": false
    },
    "optimization": {
      "recipe": {
        "optimizer": "ember_splatting_training.FusedAdam",
        "center_position_lr_init": 0.00016,
        "center_position_lr_final": 0.0000016,
        "center_position_lr_max_steps": 30000,
        "center_position_lr_step_offset": 1,
        "sh_dc_lr": 0.0025,
        "sh_rest_lr": 0.000125,
        "logit_opacity_lr": 0.025,
        "log_scales_lr": 0.005,
        "quaternion_orientation_lr": 0.001
      }
    },
    "loss": {
      "lambda_l1": 0.8,
      "lambda_dssim": 0.2,
      "lambda_opacity_regularization": 0.0,
      "lambda_scale_regularization": 0.0
    },
    "densification": {
      "mode": "vanilla",
      "vanilla": {
        "refine_every": 100,
        "start_iter": 600,
        "stop_iter": 14900,
        "grad_threshold": 0.0002,
        "dense_fraction": 0.01,
        "prune_opacity_threshold": 0.005,
        "opacity_reset_every": 3000,
        "extra_opacity_reset_iter": null,
        "max_reset_opacity": 0.01
      },
      "morton": {
        "schedule": {
          "end_iteration": 15000,
          "frequency": 5000
        }
      },
      "antialiasing": {
        "recompute_schedule": {
          "start_iteration": 15000,
          "end_iteration": 29899,
          "frequency": 100
        },
        "near_plane": 0.2
      },
      "final_cleanup": {
        "min_opacity": 0.00392156862745098
      }
    },
    "checkpoint": {
      "output_dir": "checkpoints/papers/fastergs/garden_baseline/adapter.fastergs",
      "export_ply": true
    }
  }
}
