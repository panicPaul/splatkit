      "relative_size_threshold": 0.01,
      "split_n_gaussians": 2,
      "prune_frequency": 100,
      "prune_start_iteration": 500,
      "prune_end_iteration": 15000,
      "prune_density_threshold": 0.005,
      "reset_density_frequency": 3000,
      "reset_density_start_iteration": 0,
      "reset_density_end_iteration": 15000,
      "reset_density_new_max_density": 0.01,
