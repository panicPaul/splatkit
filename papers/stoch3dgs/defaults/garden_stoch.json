  "training": {
    "runtime": {
      "device": "cuda",
      "seed": 0,
      "max_steps": 30000
    },
    "profiler": {
      "enabled": false,
      "log_every": 100,
      "output_path": null
    },
    "batching": {
      "batch_size": 1,
      "shuffle": true,
      "num_workers": 4,
      "persistent_workers": true,
      "pin_memory": true
