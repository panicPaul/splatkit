{
  "preset": "garden_debug_val",
  "scene": {
    "path": "dataset/mipnerf360/garden",
    "image_root": null,
    "undistort_output_dir": null,
    "align_horizon": true
  },
  "data": {
    "camera_sensor_id": null,
    "image_scale_factor": 0.25,
    "cache_resized_images": true,
    "resized_image_cache_root": null,
    "max_resized_image_caches": 4,
    "split_target": "val",
    "split_every_n": 8,
    "materialization_stage": "prepared",
    "materialization_mode": "eager",
    "materialization_num_workers": 8,
    "normalize_images": true,
    "interpolation": "bicubic"
  },
  "training": {
    "runtime": {
      "device": "cuda",
      "seed": 3721,
      "max_steps": 2
    },
    "profiler": {
      "enabled": false,
      "log_every": 10,
      "output_path": null
    },
    "batching": {
      "batch_size": 1,
      "shuffle": true,
      "num_workers": 8,
      "persistent_workers": true,
      "pin_memory": true
    },
    "checkpoint": {
      "output_dir": "checkpoints/papers/svraster/garden_debug_val/svraster.core",
      "export_ply": false,
      "overwrite": true
    },
    "model": {
      "backend_name": "new_cuda",
      "max_num_levels": 21,
      "runtime_max_num_levels": 21,
      "sh_degree": 1,
      "initial_sh_degree": 1,
      "samples_per_voxel": 1,
      "render_supersampling": 1.0,
      "ss_aug_max": 1.0,
      "white_background": false,
      "black_background": false
    },
    "initialization": {
      "initial_inside_level": 3,
      "outside_level": 2,
      "initial_outside_ratio": 1.5,
      "geometry_initial_value": -10.0,
      "sh0_initial_rgb": 0.5,
      "shs_initial_value": 0.0,
      "bound_mode": "default",
      "bound_scale": 1.0,
      "forward_distance_scale": 1.0,
      "filter_zero_visibility": true
    },
    "optimization": {
      "geo_lr": 0.025,
      "sh0_lr": 0.01,
      "shs_lr": 0.00025,
      "beta1": 0.1,
      "beta2": 0.99,
      "epsilon": 1e-15,
      "lr_decay_checkpoints": [],
      "lr_decay_multiplier": 0.1
    },
    "loss": {
      "lambda_photo": 1.0,
      "lambda_ssim": 0.0,
      "use_l1": true,
      "use_huber": false,
      "huber_threshold": 0.03,
      "lambda_t_concentration": 0.0,
      "lambda_t_inside": 0.01,
      "lambda_r_concentration": 0.01,
      "lambda_ascending": 0.0,
      "ascending_start_step": 0,
      "lambda_distortion": 0.0,
      "distortion_start_step": 0,
      "ssim_backend": "cuda"
    },
    "regularization": {
      "tv_density_weight": 0.0,
      "tv_start_step": 0,
      "tv_end_step": 0
    },
    "adaptive": {
      "adapt_from": 0,
      "adapt_every": 100,
      "prune_until": 0,
      "prune_threshold_initial": 0.0001,
      "prune_threshold_final": 0.01,
      "subdivide_until": 0,
      "subdivide_all_until": 0,
      "subdivide_sample_threshold": 1.0,
      "subdivide_proportion": 0.05,
      "subdivide_max_voxels": 100000
    },
    "viewer": {
      "enabled": true,
      "update_every_steps": 500,
      "min_update_seconds": 2.0,
      "pause_on_interaction": true,
      "pause_poll_seconds": 0.05,
      "max_pause_seconds": null
    }
  }
}
